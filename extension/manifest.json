{
  "manifest_version": 3,
  "name": "Ujjawal Groups Website Audit AI",
  "version": "2.0.0",
  "description": "5-Pass Empirical Website Quality Index (WQI) Audit Engine by Ujjawal Sharma & Ujjawal Groups. 1-click active tab website auditing.",
  "author": "Ujjawal Sharma",
  "homepage_url": "https://ujjawal-group-website-audit.vercel.app/",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Audit Active Website with Ujjawal Groups WAEF v2.0",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
